# Local development:  http://localhost:3001/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# Request timeout in milliseconds (default: 10 s)
EXPO_PUBLIC_API_TIMEOUT=10000

EXPO_PUBLIC_DEFAULT_VEHICLE_ID=VH001
EXPO_PUBLIC_DEFAULT_FLEET_ID=1
EXPO_PUBLIC_DEFAULT_USER_ID=11

# ------------------------------------------------------------------------------
# Default map centre
# Used when device location permission is denied or unavailable.
# Default: Bangalore, Karnataka, India
# ------------------------------------------------------------------------------

EXPO_PUBLIC_DEFAULT_LAT=12.9716
EXPO_PUBLIC_DEFAULT_LNG=77.5946

# One of: development | staging | production
EXPO_PUBLIC_ENV=development
